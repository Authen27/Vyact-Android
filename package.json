{
  "name": "vyact-react",
  "private": true,
  "version": "9.7.1",
  "type": "module",
  "description": "Vyact — Family Finance OS · React + TypeScript + Recharts",
  "scripts": {
    "dev": "vite",
    "build": "node check-env.js && tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:stability": "node e2e/run-stability.cjs",
    "e2e:capture": "node e2e/run-and-capture.cjs",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@dinero.js/currencies": "^2.0.0-alpha.14",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@tanstack/react-virtual": "^3.13.25",
    "@userback/widget": "^0.3.12",
    "@vercel/speed-insights": "^2.0.0",
    "dinero.js": "^2.0.2",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.453.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "recharts": "^2.13.0",
    "vyact-react": "file:",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@playwright/test": "^1.60.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "gifenc": "^1.0.3",
    "globals": "^15.11.0",
    "pngjs": "^7.0.0",
    "postcss": "^8.4.47",
    "puppeteer-core": "^23.11.1",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.11.0",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8",
    "workbox-window": "^7.4.1"
  }
