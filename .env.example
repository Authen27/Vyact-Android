# FinFlow v4.1 — Cloud configuration
#
# Copy this file to `.env.local` (LOCAL DEV) or set in Vercel dashboard (PRODUCTION).
# The app boots in LocalStorage-only "anonymous mode" if these are unset
# — every existing v6/v7 feature still works without a backend.

# Your Supabase project URL.
# Find it in: https://supabase.com/dashboard → Project → Settings → API → Project URL
# Example: https://your-project.supabase.co
VITE_SUPABASE_URL=

# Your Supabase anon (public) key — safe to ship to the browser.
# Find it in: https://supabase.com/dashboard → Project → Settings → API → anon / public
# Example: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_SUPABASE_ANON_KEY=

# Optional — base URL the app is hosted at (used in invitation emails and auth redirects).
# For LOCAL DEV: leave unset (defaults to http://localhost:5173)
# For VERCEL: set to https://your-finflow.vercel.app or custom domain
# For Vercel, you can use the VERCEL_URL system var: https://$VERCEL_URL
VITE_APP_URL=
